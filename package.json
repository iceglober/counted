{
  "name": "counted",
  "private": true,
  "description": "Privacy-focused app analytics with composable dashboards",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceglober/counted.git"
  },
  "homepage": "https://counted.dev",
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
