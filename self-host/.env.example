# Required
BETTER_AUTH_SECRET=   # openssl rand -base64 32
BASE_URL=http://localhost:3000

# Database (change in production)
POSTGRES_PASSWORD=counted

# Email (optional). Without a key, magic links print to `docker compose logs app`.
RESEND_API_KEY=
RESEND_FROM=

# Alerts scheduler (optional). Enables the `cron` service to evaluate alerts
# every 5 minutes. Leave empty to disable. Generate: openssl rand -hex 32
CRON_SECRET=
