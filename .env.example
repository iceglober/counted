# Database (Postgres + TimescaleDB)
DATABASE_URL=postgres://localhost:5432/counted

# Auth (better-auth)
BETTER_AUTH_SECRET=   # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000

# Social sign-in (optional — leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Counted <onboarding@auth.counted.dev>

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY_ID=price_...
STRIPE_PRICE_ANNUAL_ID=price_...

# Dog-food analytics
NEXT_PUBLIC_COUNTED_PROJECT_KEY=
NEXT_PUBLIC_COUNTED_HOST=https://app.counted.dev

# Cloudflare origin guard (optional). When set, the app rejects any request that
# doesn't carry "X-Origin-Auth: <this value>" — which Cloudflare injects via a
# Transform Rule — so only Cloudflare-proxied traffic reaches the origin. Leave
# empty to disable. Only set it AFTER the Cloudflare Transform Rule is live, or
# you will 403 all traffic. Generate: openssl rand -hex 32
ORIGIN_GUARD_SECRET=

# Finance dogfood (optional). When set, the Stripe webhook emits `revenue`
# events into a Counted "finance" project so Counted measures its own MRR/burn.
# No-op until set. Use the finance project's client key (ck_…). See financial-ops.md.
COUNTED_FINANCE_KEY=
COUNTED_FINANCE_HOST=https://app.counted.dev

# Deploy/crash alerts via email (Railway webhook -> /api/internal/railway-hook).
# Set RAILWAY_HOOK_SECRET to a random string, point a Railway webhook at
# https://app.counted.dev/api/internal/railway-hook?token=<that secret>.
# Failure/crash deploys email OPS_ALERT_EMAIL via Resend. openssl rand -hex 16
RAILWAY_HOOK_SECRET=
OPS_ALERT_EMAIL=austin@iceglobe.io

# Search-console ownership verification (optional). Paste the token from the
# HTML-tag verification method, then redeploy. Google Search Console -> Settings
# -> Ownership verification -> HTML tag (copy the `content` value).
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
