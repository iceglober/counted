# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Counted <onboarding@auth.counted.dev>

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
