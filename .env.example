# Database (Postgres + TimescaleDB)
DATABASE_URL=postgres://localhost:5432/counted

# Auth (better-auth)
BETTER_AUTH_SECRET=   # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
