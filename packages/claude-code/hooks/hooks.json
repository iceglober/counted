{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/counted-hook.mjs\"",
            "env": { "COUNTED_AGENT_KEY": "${user_config.api_key}", "COUNTED_AGENT_HOST": "${user_config.host}" },
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/counted-hook.mjs\"",
            "env": { "COUNTED_AGENT_KEY": "${user_config.api_key}", "COUNTED_AGENT_HOST": "${user_config.host}" },
            "async": true,
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/counted-hook.mjs\"",
            "env": { "COUNTED_AGENT_KEY": "${user_config.api_key}", "COUNTED_AGENT_HOST": "${user_config.host}" },
            "timeout": 10
          }
        ]
      }
    ]
  }
}
