{
  "name": "@counted/cursor",
  "displayName": "Counted Analytics",
  "description": "Privacy-first coding analytics for Cursor and VS Code — track file edits, terminal commands, and sessions without collecting content",
  "version": "0.1.0",
  "publisher": "iceglobe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceglober/counted.git",
    "directory": "packages/cursor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["analytics", "privacy", "cursor", "telemetry", "counted"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Counted Analytics",
      "properties": {
        "counted.projectKey": {
          "type": "string",
          "default": "",
          "description": "Your Counted project key (ck_...)"
        },
        "counted.host": {
          "type": "string",
          "default": "https://app.counted.dev",
          "description": "Counted API host URL"
        },
        "counted.trackFileSaves": {
          "type": "boolean",
          "default": true,
          "description": "Track file save events (path and language only, no content)"
        },
        "counted.trackTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Track terminal open/close events (no command content)"
        },
        "counted.trackSessions": {
          "type": "boolean",
          "default": true,
          "description": "Track editor session start/end"
        }
      }
    },
    "commands": [
      {
        "command": "counted.setProjectKey",
        "title": "Counted: Set Project Key"
      },
      {
        "command": "counted.showStatus",
        "title": "Counted: Show Status"
      }
    ]
  },
  "scripts": {
    "build": "tsup src/extension.ts --format cjs --out-dir dist --external vscode --no-dts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@counted/sdk": "workspace:*"
  }
}
