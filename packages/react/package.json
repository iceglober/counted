{
  "name": "@counted/react",
  "version": "0.1.2",
  "description": "React hooks for @counted/sdk",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./aptabase": {
      "types": "./dist/aptabase.d.ts",
      "import": "./dist/aptabase.js",
      "require": "./dist/aptabase.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iceglober/counted.git",
    "directory": "packages/react"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@counted/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3",
    "@counted/sdk": "workspace:*"
  }
}
